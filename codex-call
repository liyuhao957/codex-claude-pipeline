#!/bin/bash
set -euo pipefail

# --- Resolve codex binary ---
if command -v codex &>/dev/null; then
    CODEX_BIN="codex"
elif [[ -x "/Applications/Codex.app/Contents/Resources/codex" ]]; then
    CODEX_BIN="/Applications/Codex.app/Contents/Resources/codex"
else
    echo "ERROR: codex not found in PATH or at /Applications/Codex.app/Contents/Resources/codex" >&2
    exit 127
fi

# --- Timeout (default 600s, override via CODEX_TIMEOUT) ---
TIMEOUT="${CODEX_TIMEOUT:-600}"
if ! [[ "$TIMEOUT" =~ ^[0-9]+$ ]] || [[ "$TIMEOUT" -eq 0 ]]; then
    echo "ERROR: CODEX_TIMEOUT must be a positive integer (got: '$TIMEOUT')" >&2
    exit 1
fi

# --- Resolve timeout command (not available by default on macOS) ---
TIMEOUT_CMD=""
if command -v timeout &>/dev/null; then
    TIMEOUT_CMD="timeout"
elif command -v gtimeout &>/dev/null; then
    TIMEOUT_CMD="gtimeout"
else
    echo "WARN: neither 'timeout' nor 'gtimeout' found; running without timeout" >&2
fi

# --- Parse arguments ---
SESSION_FILE=""
RESUME_ID=""
SAVE_OUTPUT=""
PROMPT=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --session-file)
            SESSION_FILE="$2"
            shift 2
            ;;
        --resume)
            RESUME_ID="$2"
            shift 2
            ;;
        --save-output)
            SAVE_OUTPUT="$2"
            shift 2
            ;;
        -)
            shift
            PROMPT="$(cat)"
            break
            ;;
        -*)
            echo "ERROR: unknown option: $1" >&2
            exit 1
            ;;
        *)
            PROMPT="$1"
            shift
            break
            ;;
    esac
done

# If no prompt yet and stdin has data
if [[ -z "$PROMPT" && ! -t 0 ]]; then
    PROMPT="$(cat)"
fi

if [[ -z "$PROMPT" ]]; then
    echo "ERROR: no prompt provided" >&2
    echo "Usage: codex-call [--session-file PATH] [--resume SESSION_ID] [--save-output PATH] \"prompt\"" >&2
    echo "       echo \"prompt\" | codex-call [--session-file PATH] [--save-output PATH] -" >&2
    exit 1
fi

# --- Build codex arguments ---
CODEX_ARGS=(exec --sandbox read-only)

if [[ -n "$SESSION_FILE" ]]; then
    CODEX_ARGS+=(--json)
fi

if [[ -n "$RESUME_ID" ]]; then
    CODEX_ARGS+=(resume "$RESUME_ID")
fi

CODEX_ARGS+=("$PROMPT")

# --- Execute ---
if [[ -z "$SESSION_FILE" ]]; then
    # Simple mode: no session tracking, plain text output (backward compatible)
    if [[ -n "$SAVE_OUTPUT" ]]; then
        # Pipe through tee to save output while still printing to stdout
        if [[ -n "$TIMEOUT_CMD" ]]; then
            "$TIMEOUT_CMD" "$TIMEOUT" "$CODEX_BIN" "${CODEX_ARGS[@]}" | tee "$SAVE_OUTPUT"
        else
            "$CODEX_BIN" "${CODEX_ARGS[@]}" | tee "$SAVE_OUTPUT"
        fi
    else
        if [[ -n "$TIMEOUT_CMD" ]]; then
            exec "$TIMEOUT_CMD" "$TIMEOUT" "$CODEX_BIN" "${CODEX_ARGS[@]}"
        else
            exec "$CODEX_BIN" "${CODEX_ARGS[@]}"
        fi
    fi
else
    # Session mode: JSON output, parse to extract text + session ID
    TMPFILE="$(mktemp)"
    trap 'rm -f "$TMPFILE"' EXIT

    EXIT_CODE=0
    if [[ -n "$TIMEOUT_CMD" ]]; then
        "$TIMEOUT_CMD" "$TIMEOUT" "$CODEX_BIN" "${CODEX_ARGS[@]}" > "$TMPFILE" 2>&1 || EXIT_CODE=$?
    else
        "$CODEX_BIN" "${CODEX_ARGS[@]}" > "$TMPFILE" 2>&1 || EXIT_CODE=$?
    fi

    # Parse JSON output with python3 (available on macOS by default)
    python3 -c "
import sys, json

text_parts = []
session_id = ''

for line in open(sys.argv[1]):
    line = line.strip()
    if not line:
        continue
    try:
        event = json.loads(line)
    except (json.JSONDecodeError, ValueError):
        continue

    # Extract session ID from thread.started event
    if event.get('type') == 'thread.started':
        tid = event.get('thread_id', '')
        if tid:
            session_id = tid

    # Extract text from item.completed events
    if event.get('type') == 'item.completed':
        item = event.get('item', {})
        if isinstance(item, dict) and item.get('type') == 'agent_message':
            text = item.get('text', '')
            if isinstance(text, list):
                text = ''.join(str(t) for t in text)
            if text:
                text_parts.append(str(text))

# Output text to stdout
output_text = '\n'.join(text_parts) if text_parts else ''
if output_text:
    print(output_text)

# Save session ID to file
if session_id and len(sys.argv) > 2:
    with open(sys.argv[2], 'w') as f:
        f.write(session_id)
    print(f'SESSION_ID: {session_id}', file=sys.stderr)

# Save output to file if requested
if len(sys.argv) > 3 and sys.argv[3] and output_text:
    with open(sys.argv[3], 'w') as f:
        f.write(output_text)
" "$TMPFILE" "$SESSION_FILE" "$SAVE_OUTPUT"

    exit "$EXIT_CODE"
fi
