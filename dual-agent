#!/usr/bin/env python3
"""Codex x Claude Code dual-agent orchestrator."""

import argparse
import os
import re
import shutil
import subprocess
import sys
from datetime import datetime
from pathlib import Path

DESIGN_DIR = ".design"
DEFAULT_MAX_ROUNDS = 3
VERDICT_RE = re.compile(r"VERDICT:\s*(PASS|REVISE)", re.IGNORECASE)
CALL_TIMEOUT = 600  # 10 minutes per agent call

CODEX_FALLBACK = "/Applications/Codex.app/Contents/Resources/codex"
CODEX_BIN = None  # resolved at startup
CODEX_SKIP_SANDBOX = False  # --yolo mode


class AgentError(RuntimeError):
    """Raised when an agent CLI returns non-zero exit code."""


def set_timeout(value):
    global CALL_TIMEOUT
    CALL_TIMEOUT = value


def log(phase, msg):
    ts = datetime.now().strftime("%H:%M:%S")
    print(f"\n{'='*60}")
    print(f"[{ts}] [{phase}] {msg}")
    print(f"{'='*60}")


def _run(cmd):
    label = Path(cmd[0]).stem
    try:
        result = subprocess.run(
            cmd, capture_output=True, text=True, timeout=CALL_TIMEOUT
        )
    except subprocess.TimeoutExpired:
        raise AgentError(
            f"'{label}' timed out after {CALL_TIMEOUT}s"
        )
    if result.returncode != 0:
        detail = (result.stderr or result.stdout or "")[:500]
        raise AgentError(
            f"'{label}' exited with code {result.returncode}: {detail}"
        )
    return result.stdout


def run_codex(prompt, writable=False):
    cmd = [CODEX_BIN, "exec"]
    if CODEX_SKIP_SANDBOX:
        cmd.append("--dangerously-bypass-approvals-and-sandbox")
    elif writable:
        cmd.append("--full-auto")
    else:
        cmd.extend(["--sandbox", "read-only"])
    cmd.append(prompt)
    return _run(cmd)


def run_codex_review(flags, extra_prompt=""):
    cmd = [CODEX_BIN, "review"]
    if CODEX_SKIP_SANDBOX:
        cmd.append("--dangerously-bypass-approvals-and-sandbox")
    cmd.extend(flags)
    if extra_prompt:
        cmd.append(extra_prompt)
    return _run(cmd)


def run_claude(prompt):
    return _run(["claude", "-p", "--dangerously-skip-permissions", prompt])


def parse_verdict(output):
    matches = VERDICT_RE.findall(output)
    if matches:
        return matches[-1].upper()
    return "REVISE"


def append_debate(filepath, round_num, role, content):
    with open(filepath, "a") as f:
        f.write(f"\n## Round {round_num} -- {role}\n\n{content}\n")


def _fail(reason, artifact):
    print(f"\n{'!'*60}")
    print(f"STOPPED: {reason}")
    print(f"Check {artifact} for unresolved issues.")
    print(f"{'!'*60}")
    sys.exit(1)


def resolve_codex():
    global CODEX_BIN
    path_bin = shutil.which("codex")
    if path_bin:
        CODEX_BIN = path_bin
        return
    if os.path.isfile(CODEX_FALLBACK) and os.access(CODEX_FALLBACK, os.X_OK):
        CODEX_BIN = CODEX_FALLBACK
        return
    print("Error: 'codex' not found in PATH or at "
          f"{CODEX_FALLBACK}", file=sys.stderr)
    sys.exit(1)


def check_prerequisites():
    resolve_codex()
    if not shutil.which("claude"):
        print("Error: 'claude' not found in PATH.", file=sys.stderr)
        sys.exit(1)


def ensure_git_repo():
    result = subprocess.run(
        ["git", "rev-parse", "--is-inside-work-tree"],
        capture_output=True, text=True
    )
    if result.returncode != 0:
        print("Error: not a git repository.", file=sys.stderr)
        print("Phase 3 needs git diff. Please run:", file=sys.stderr)
        print("  git init && git add . && git commit -m 'baseline'",
              file=sys.stderr)
        sys.exit(1)


def phase_design_debate(requirement, max_rounds):
    log("Phase 1", "Design Debate")
    debate_file = f"{DESIGN_DIR}/design-debate.md"
    design_file = f"{DESIGN_DIR}/design.md"

    for rnd in range(1, max_rounds + 1):
        # Codex writes or revises design
        if rnd == 1:
            log("Phase 1", f"Round {rnd} -- Codex writing initial design")
            prompt = (
                f"Requirement: {requirement}\n\n"
                f"Examine this codebase, then write a design document "
                f"to {design_file}.\n"
                f"Include: Goal/Non-goals, Interface definitions, "
                f"File change list, Edge cases."
            )
        else:
            log("Phase 1", f"Round {rnd} -- Codex revising design")
            prompt = (
                f"Read {design_file} and {debate_file} for review feedback.\n"
                f"Revise the design to address all P0 and P1 issues.\n"
                f"Update {design_file} with the revised design."
            )
        output = run_codex(prompt, writable=True)
        append_debate(debate_file, rnd, "Codex (design)", output)

        # Claude Code reviews
        log("Phase 1", f"Round {rnd} -- Claude Code reviewing design")
        review_prompt = (
            f"Review the design document at {design_file}. "
            f"Also read {debate_file} for debate history.\n\n"
            f"Do NOT modify any code. Only review the design.\n"
            f"Categorize issues as P0 (must fix), P1 (should fix), "
            f"P2 (nice to have).\n\n"
            f"End with exactly: VERDICT: PASS or VERDICT: REVISE"
        )
        review = run_claude(review_prompt)
        append_debate(debate_file, rnd, "Claude Code (review)", review)

        verdict = parse_verdict(review)
        if verdict == "PASS":
            log("Phase 1", f"Design PASSED at round {rnd}")
            return True
        log("Phase 1", f"Round {rnd} verdict: REVISE")

    return False


def phase_implement():
    log("Phase 2", "Claude Code implementing")
    design_file = f"{DESIGN_DIR}/design.md"
    changeset_file = f"{DESIGN_DIR}/changeset.md"
    prompt = (
        f"Read the approved design at {design_file}.\n"
        f"Implement all code changes described in the design.\n"
        f"After implementation, run the project build/test commands.\n"
        f"Write a changeset summary to {changeset_file} including:\n"
        f"- Files modified/created\n- Risk points\n"
        f"- Items needing confirmation"
    )
    output = run_claude(prompt)
    log("Phase 2", "Implementation complete")
    return output


def phase_code_debate(max_rounds):
    log("Phase 3", "Implementation Debate")
    debate_file = f"{DESIGN_DIR}/implementation-debate.md"
    design_file = f"{DESIGN_DIR}/design.md"
    changeset_file = f"{DESIGN_DIR}/changeset.md"

    for rnd in range(1, max_rounds + 1):
        # Codex reviews code using native review command
        log("Phase 3", f"Round {rnd} -- Codex reviewing code")
        extra = (
            f"Also read {design_file} for design intent, "
            f"{changeset_file} for change summary, "
            f"and {debate_file} for previous review history. "
            f"Categorize issues as P0, P1, P2. "
            f"End with exactly: VERDICT: PASS or VERDICT: REVISE"
        )
        review = run_codex_review(["--uncommitted"], extra)
        append_debate(debate_file, rnd, "Codex (review)", review)

        verdict = parse_verdict(review)
        if verdict == "PASS":
            log("Phase 3", f"Implementation PASSED at round {rnd}")
            return True
        log("Phase 3", f"Round {rnd} verdict: REVISE")

        if rnd == max_rounds:
            break

        # Claude Code fixes
        log("Phase 3", f"Round {rnd} -- Claude Code fixing issues")
        fix_prompt = (
            f"Read {debate_file} for the latest code review feedback.\n"
            f"Fix all P0 and P1 issues from the review.\n"
            f"After fixing, run the project build/test commands.\n"
            f"Update {changeset_file} with what you changed."
        )
        fix_output = run_claude(fix_prompt)
        append_debate(debate_file, rnd, "Claude Code (fix)", fix_output)

    return False


def main():
    parser = argparse.ArgumentParser(
        description="Codex x Claude Code dual-agent pipeline"
    )
    parser.add_argument("requirement", help="Feature requirement")
    parser.add_argument(
        "--max-rounds", type=int, default=DEFAULT_MAX_ROUNDS,
        help=f"Max debate rounds per phase (default: {DEFAULT_MAX_ROUNDS})"
    )
    parser.add_argument(
        "--timeout", type=int, default=CALL_TIMEOUT,
        help=f"Timeout per agent call in seconds (default: {CALL_TIMEOUT})"
    )
    parser.add_argument(
        "--yolo", action="store_true",
        help="Use --dangerously-bypass-approvals-and-sandbox for all Codex calls"
    )
    args = parser.parse_args()

    set_timeout(args.timeout)
    if args.yolo:
        global CODEX_SKIP_SANDBOX
        CODEX_SKIP_SANDBOX = True

    check_prerequisites()
    ensure_git_repo()
    Path(DESIGN_DIR).mkdir(exist_ok=True)

    start = datetime.now()
    log("Start", f"Requirement: {args.requirement}")
    log("Start", f"Max rounds: {args.max_rounds}, Timeout: {CALL_TIMEOUT}s")

    try:
        if not phase_design_debate(args.requirement, args.max_rounds):
            _fail(f"Design debate did not pass in {args.max_rounds} rounds.",
                  f"{DESIGN_DIR}/design-debate.md")
        phase_implement()
        if not phase_code_debate(args.max_rounds):
            _fail(f"Code review did not pass in {args.max_rounds} rounds.",
                  f"{DESIGN_DIR}/implementation-debate.md")
    except AgentError as e:
        print(f"\n{'!'*60}", file=sys.stderr)
        print(f"AGENT FAILED: {e}", file=sys.stderr)
        print(f"{'!'*60}", file=sys.stderr)
        sys.exit(2)

    elapsed = datetime.now() - start
    log("Done", f"Pipeline completed successfully in {elapsed}")
    print(f"\nArtifacts in {DESIGN_DIR}/:")
    for f in sorted(Path(DESIGN_DIR).iterdir()):
        print(f"  {f}")


if __name__ == "__main__":
    main()
